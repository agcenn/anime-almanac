PORT=3000
DATABASE_PATH=./data/anime.db
# node-schedule cron：每天北京时间 03:15 更新
SYNC_CRON=15 3 * * *
SYNC_TIMEZONE=Asia/Shanghai
# AniList 公共 GraphQL 查询无需 API Key
ANILIST_ENDPOINT=https://graphql.anilist.co
# 首次同步的历史范围；可按需要调大
SYNC_HISTORY_YEARS=6
ANILIST_TIMEOUT_MS=60000
# 正式译名和同系列推断仍缺失时，使用 MyMemory 机器翻译并缓存
TITLE_TRANSLATION_ENABLED=true
MYMEMORY_ENDPOINT=https://api.mymemory.translated.net/get
TITLE_TRANSLATION_DELAY_MS=350
TITLE_TRANSLATION_TIMEOUT_MS=8000
